     5                                  
     6                                  
     7                                  ; [FORMAT "WCOFF"]        ; 制作目标文件的模式 (nask)
     8                                  ; [INSTRSET "i486p"]      ; 使用到486为止的指令 (nask)
     9                                  [BITS 32]                 ; 制作 32 位模式用的机器语言
    10                                  
    11                                  
    12                                  ; 制作目标文件的信息
    13                                  ; [FILE "nasmfunc.nasm"]  ; 源文件名信息 (nask)
    14                                  
    15                                  ; 程序中包含的函数名
    16                                    GLOBAL _io_hlt, _write_mem8
    17                                  
    18                                  
    19                                  ; 以下是实际的函数
    20                                  [SECTION .text]           ; 目标文件中写了这些之后再写程序
    21                                  
    22                                  _io_hlt:                  ; void io_hlt(void);
    23 00000000 F4                        HLT
    24 00000001 C3                        RET
    25                                  
    26                                  
    27                                  ; will data to addr store
    28                                  _write_mem8:              ; void write_mem8(int addr, int data);
    29 00000002 8B4C2404                  MOV   ECX, [ESP + 4]    ; [ESP + 4] 中存放的是地址， 将其读入 ECX; bits 32 / 8 = 4 unit
    30 00000006 8A442408                  MOV   AL,  [ESP + 8]    ; [ESP + 8] 中存放的是数据， 将其读入 AL ; etc.
    31 0000000A 8801                      MOV   [ECX], AL         ; 将数据存入内存
    32 0000000C C3                        RET
    33                                  
    34                                  
