     1                                  ; path: rozi/days/day04/nasmfunc01f.nasm
     2                                  ; author: redskaber
     3                                  ; format: TAB=2
     4                                  ; datetime: 2026-06-06
     5                                  
     6                                  
     7                                  ; [FORMAT "WCOFF"]        ; 制作目标文件的模式 (nask)
     8                                  ; [INSTRSET "i486p"]      ; 使用到486为止的指令 (nask)
     9                                  [BITS 32]                 ; 制作 32 位模式用的机器语言
    10                                  
    11                                  
    12                                  ; 制作目标文件的信息
    13                                  ; [FILE "nasmfunc.nasm"]  ; 源文件名信息 (nask)
    14                                  
    15                                  ; 程序中包含的函数名
    16                                    GLOBAL  _io_hlt, _io_cli, _io_sti, _io_stihlt
    17                                    GLOBAL  _io_in8, _io_in16, _io_in32
    18                                    GLOBAL  _io_out8, _io_out16, _io_out32
    19                                    GLOBAL  _io_load_eflags, _io_store_eflags
    20                                  
    21                                  
    22                                  ; 以下是实际的函数
    23                                  [SECTION .text]           ; 目标文件中写了这些之后再写程序
    24                                  
    25                                  ;; nasm commands to c use
    26                                  _io_hlt:                  ; void io_hlt(void);
    27 00000000 F4                        HLT
    28 00000001 C3                        RET
    29                                  
    30                                  _io_cli:                  ; void io_cli(void);
    31 00000002 FA                        CLI
    32 00000003 C3                        RET
    33                                  
    34                                  _io_sti:                  ; void io_sti(void);
    35 00000004 FB                        STI
    36 00000005 C3                        RET
    37                                  
    38                                  _io_stihlt:               ; void io_stihlt(void);
    39 00000006 FB                        STI
    40 00000007 F4                        HLT
    41 00000008 C3                        RET
    42                                  
    43                                  
    44                                  ;; nasm in commands to c use
    45                                  _io_in8:                  ; int io_in8(int port);
    46 00000009 8B542404                  MOV   EDX, [ESP + 4]    ; port
    47 0000000D B800000000                MOV   EAX, 0
    48 00000012 EC                        IN    AL, DX            ; AL 8 bits
    49 00000013 C3                        RET
    50                                  
    51                                  _io_in16:                 ; int io_in16(int port)
    52 00000014 8B542404                  MOV   EDX, [ESP + 4]    ; port
    53 00000018 B800000000                MOV   EAX, 0
    54 0000001D 66ED                      IN    AX, DX            ; AX 16 bits
    55 0000001F C3                        RET
    56                                  
    57                                  _io_in32:                 ; int io_in32(int port)
    58 00000020 8B542404                  MOV   EDX, [ESP + 4]    ; port
    59 00000024 ED                        IN    EAX, DX           ; EAX 32 bits
    60 00000025 C3                        RET
    61                                  
    62                                  
    63                                  ;; nasm out commands to c use
    64                                  _io_out8:                 ; void io_out8(int port, int data);
    65 00000026 8B542404                  MOV   EDX, [ESP + 4]    ; port
    66 0000002A 8B442408                  MOV   EAX, [ESP + 8]    ; data
    67 0000002E EE                        OUT   DX, AL            ; AL 8 bits
    68 0000002F C3                        RET
    69                                  
    70                                  _io_out16:                ; void io_out16(int port, int data);
    71 00000030 8B542404                  MOV   EDX, [ESP + 4]    ; port
    72 00000034 8B442408                  MOV   EAX, [ESP + 8]    ; data
    73 00000038 66EF                      OUT   DX, AX            ; AX 16 bits
    74 0000003A C3                        RET
    75                                  
    76                                  _io_out32:                ; void io_out32(int port, int data);
    77 0000003B 8B542404                  MOV   EDX, [ESP + 4]    ; port
    78 0000003F 8B442408                  MOV   EAX, [ESP + 8]    ; data
    79 00000043 EF                        OUT   DX, EAX           ; EAX 32 bits
    80 00000044 C3                        RET
    81                                  
    82                                  
    83                                  ;; nasm eflages contoller to c use
    84                                  _io_load_eflags:          ; int io_load_efalgs(void);
    85 00000045 9C                        PUSHFD                  ; ps. PUSH EFLAGS  (push flags double-word)
    86 00000046 58                        POP   EAX               ; 根据C语 言的规约，执行 RET 语句时，EAX 中的值就被看作是 函数的返回值
    87 00000047 C3                        RET
    88                                  
    89                                  _io_store_eflags:         ; void io_store_eflags(int eflags);
    90 00000048 8B442404                  MOV   EAX, [ESP + 4]    ; eflags
    91 0000004C 50                        PUSH  EAX
    92 0000004D 9D                        POPFD                   ; ps. POP EFLAGS (pop flags double-word)
    93 0000004E C3                        RET
    94                                  
    95                                  
