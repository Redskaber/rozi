     1                                  ; path: rozi/days/day04/rozi01a.ipl10.nasm
     2                                  ; author: redskaber
     3                                  ; format: TAB=2
     4                                  ; datetime: 2026-06-06
     5                                  ;
     6                                  ; 左移 4 位这种设计本质上就是为了解决当时的 16位存储和 20位地址之间转换关系设计
     7                                  ; 段寄存器：
     8                                  ;   段寄存器 × 16 + 偏移”的规则，只在 8086/8088 以及所有 x86 CPU 的实模式 下适用.
     9                                  ;   适用于所有段寄存器（CS、DS、ES、SS)
    10                                  
    11                                  
    12                                  ; EQU: 相当于 c 中的 #define, 用来声明常数; EQU == "equal"
    13                                  CYLS EQU 10               ; cylinders
    14                                  
    15                                  
    16                                  ORG 0x7C00
    17                                  
    18                                  
    19                                  ; standrad FAT12 format
    20 00000000 EB4E                      JMP entry
    21 00000002 90                        DB    0x90
    22 00000003 524F5A492E49504C          DB    "ROZI.IPL"        ; 启动区的名称可以是任意的字符串(8字节)
    23 0000000B 0002                      DW    512               ; 每一个扇区 (sector) 的大小(必须为512字节)
    24 0000000D 01                        DB    1                 ; 簇（cluster）的大小（必须为1个扇区
    25                                  
    26 0000000E 0100                      DW    1                 ; FAT的起始位置(一般从第一个扇区开始)
    27 00000010 02                        DB    2                 ; FAT的个数(必须为2个)
    28 00000011 E000                      DW    224               ; 根目录大大小（一般设置成224项）
    29 00000013 400B                      DW    2880              ; 该磁盘的大小（必须为2880扇区）
    30 00000015 F0                        DB    0xf0              ; 磁盘的种类（必须是0xf0）
    31 00000016 0900                      DW    9                 ; FAT的长度（必须是9扇区）
    32 00000018 1200                      DW    18                ; 1个磁道（track）有几个扇区(必须是18)
    33 0000001A 0200                      DW    2                 ; 磁头数(必须是2)
    34 0000001C 00000000                  DD    0                 ; 不使用分区，必须是0
    35 00000020 400B0000                  DD    2880              ; 重写一次磁盘大小
    36 00000024 000029                    DB    0,0,0x29          ; 扩展引导标志（BS_BootSig）,结构上是为了对齐
    37 00000027 FFFFFFFF                  DD    0xffffffff        ; 卷序列号（BS_VolID）
    38 0000002B 524F5A492020202020-       DB    "ROZI       "     ; 磁盘的名称(11字节)
    38 00000034 2020               
    39 00000036 4641543132202020          DB    "FAT12   "        ; 磁盘格式名称（8字节）
    40 0000003E 00<rep 12h>               times 18 DB 0x00        ; RESB  18 ; 空出18 字节
    41                                  
    42                                  
    43                                  ; 程序主体
    44                                  entry:
    45 00000050 B80000                    MOV   AX, 0             ; 初始化寄存器 (stack, data, extra)
    46 00000053 8ED0                      MOV   SS, AX            ; stack segment
    47 00000055 BC007C                    MOV   SP, 0x7C00        ; stak pointer
    48 00000058 8ED8                      MOV   DS, AX            ; data segment
    49                                  
    50                                    ; read disk
    51 0000005A B82008                    MOV   AX, 0x820         ; 0x8200 / 16
    52 0000005D 8EC0                      MOV   ES, AX            ; extra segment
    53 0000005F B500                      MOV   CH, 0             ; 柱面 0
    54 00000061 B600                      MOV   DH, 0             ; 磁头 0
    55 00000063 B102                      MOV   CL, 2             ; 扇区 2
    56                                  
    57                                  
    58                                  readloop:
    59 00000065 BE0000                    MOV   SI, 0             ; 记录失败次数的寄存器
    60                                  
    61                                  retry:
    62 00000068 B402                      MOV   AH, 0x02          ;  AH=0x02 : 读盘
    63 0000006A B001                      MOV   AL, 1             ; 1 个扇区
    64 0000006C BB0000                    MOV   BX, 0             ;
    65 0000006F B200                      MOV   DL, 0x00          ; A 驱动器
    66 00000071 CD13                      INT   0x13              ; 调用磁盘 BIOS 的 0x13 号函数
    67 00000073 7310                      JNC   next              ; if carry-flag == 0 then jump next tag
    68 00000075 83C601                    ADD   SI, 1             ; 失败计数加1
    69 00000078 83FE05                    CMP   SI, 5             ; compare SI, 5
    70 0000007B 7347                      JAE   error             ; if SI >= 5 then jump error tag
    71                                  
    72                                    ; reset
    73 0000007D B400                      MOV   AH, 0x00
    74 0000007F B200                      MOV   DL, 0x00
    75 00000081 CD13                      INT   0x13
    76 00000083 EBE3                      JMP   retry
    77                                  
    78                                  
    79                                  next:
    80 00000085 8CC0                      MOV   AX, ES             ; 获取disk 当前扇区的地址
    81 00000087 83C020                    ADD   AX, 0x20           ; 地址偏移 0x200 = 512 bytes; 0x200 / 16 = 0x20;
    82 0000008A 8EC0                      MOV   ES, AX             ; 更新 ES (extra segment)
    83 0000008C 80C101                    ADD   CL, 1              ; 扇区加1
    84 0000008F 80F912                    CMP   CL, 18             ; compare CL, 18
    85 00000092 76D1                      JBE   readloop           ; if CL <= 18 then jump readloop tag
    86 00000094 B101                      MOV   CL, 1              ; reset 扇区为1
    87 00000096 80C601                    ADD   DH, 1              ; 磁头加1 (背面)
    88 00000099 80FE02                    CMP   DH, 2              ; compare DH, 2
    89 0000009C 72C7                      JB    readloop           ; if DH < 2 then jump readloop tag
    90 0000009E B600                      MOV   DH, 0              ; reset 磁头0 （正面）
    91 000000A0 80C501                    ADD   CH, 1              ; 柱面+1
    92 000000A3 80FD0A                    CMP   CH, CYLS           ; compare CH, CYLS
    93 000000A6 72BD                      JB    readloop           ; if CH < CYLS then jump readloop tag
    94 000000A8 882EF00F                  MOV   [0x0FF0], CH       ; 磁盘装载内容的结束地址告诉给 sys
    95 000000AC E9(00C2)                  JMP   0xC200             ; load 10 cylinders to jump 0xC200 (sys data)
    96                                  
    97                                  
    98                                  putloop:
    99 000000AF 8A04                      MOV   AL, [SI]          ; get source index address internal value to AL
   100 000000B1 83C601                    ADD   SI, 1             ; source index offset next address
   101 000000B4 3C00                      CMP   AL, 0             ; compare si value eq 0
   102 000000B6 7409                      JE    fin               ; je = if compare is true then jump to fin label
   103 000000B8 B40E                      MOV   AH, 0x0e          ; else
   104 000000BA BB0F00                    MOV   BX, 15
   105 000000BD CD10                      INT   0X10              ; interrupt (int): call `id` number function (bios builtins)
   106 000000BF EBEE                      JMP   putloop
   107                                  fin:
   108 000000C1 F4                        HLT                     ; quite-stop: stop run-forever, to cpu sleep; htl => halt => stop
   109 000000C2 EBFD                      JMP   fin
   110                                  
   111                                  
   112                                  error:
   113 000000C4 BE[C700]                  MOV SI, errmsg          ; source index
   114                                  
   115                                  errmsg:
   116 000000C7 0A0A                      DB    0x0a, 0x0a        ; 2 个换行
   117 000000C9 6C6F6164206572726F-       DB    "load error"
   117 000000D2 72                 
   118 000000D3 0A                        DB    0x0a              ; 换行
   119 000000D4 00                        DB    0
   120                                  
   121 000000D5 00<rep 129h>              times  0x1fe-($-$$) DB 0x00   ; RESB 0x1fe-$; 填写0x00,直到 0x001fe  (nask)
   122                                                                  ; nasm: $  表示当前 section 的起始地址（默认从 0 开始）（段内偏移）
   123                                                                  ; nasm: $$ 表示从开始到当前位置的字节数                 (段基址)
   124 000001FE 55AA                      DB    0x55, 0xaa              ; 512 字节
   125                                  
   126                                  
   127                                  ; only 512 bytes
   128                                  
   129                                  ; C0-H0-S1              : 0x7C00 -- (0x200     ) --> 0x7E00
   130                                  ; C0-H0-S(2-18)         : 0x8200 -- (0x200 * 17) --> 0xA3FF
   131                                  ; C(0-9)-H(0-1)-S(1-18) : 0x8200 -- (0x200 * 2 * 18 * 10 - 0x200) --> 0x34FFF  !(C0-H0-S1)
